{
    "name": "sbm-portal-monorepo",
    "private": true,
    "devDependencies": {
        "concurrently": "^9.2.1",
        "eslint": "^9.39.4",
        "prettier": "^3.8.1",
        "prettier-plugin-tailwindcss": "^0.7.2"
    },
    "scripts": {
        "format": "prettier --write \"**/*.{ts,js,tsx,jsx}\"",
        "format:check": "prettier --check .",
        "install:all": "npm install",
        "build:frontend": "cd frontend && npm run build",
        "start:backend": "cd backend && npm run start",
        "dev:frontend": "cd frontend && npm run dev",
        "dev:backend": "cd backend && npm run serve",
        "dev:full": "npm install && concurrently \"npm run dev:frontend\" \"npm run dev:backend\""
    },
    "workspaces": [
        "frontend",
        "backend"
    ]
}
